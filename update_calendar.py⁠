import os
import requests

# The calendar link with your unique token
CALENDAR_URL = "https://unibocconi.prod.up.cineca.it:443/api/FiltriICal/impegniICal?id=6a452917c588470014923832"

# Pretend to be a standard web browser so the university server doesn't block the automated script
headers = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
}

print("Fetching calendar data...")
response = requests.get(CALENDAR_URL, headers=headers)

if response.status_code == 200 and "BEGIN:VCALENDAR" in response.text:
    with open("calendar.ics", "w", encoding="utf-8") as f:
        f.write(response.text)
    print("Calendar updated successfully!")
elif response.status_code == 200:
    print("Server responded, but it returned a login portal page instead of a calendar.")
    print("Response snippet:", response.text[:200])
    exit(1)
else:
    print(f"Failed to fetch calendar. Status code: {response.status_code}")
    exit(1)
